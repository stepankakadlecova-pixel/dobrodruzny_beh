<!DOCTYPE html>
<html lang="cs">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Dobrodružný expres</title>

  <style>
    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      font-family: Arial, sans-serif;
      background: #f6fbff;
      overflow: hidden;
      touch-action: manipulation;
    }

    #game {
      position: relative;
      width: 100vw;
      height: 100vh;
      background: linear-gradient(#cdefff 0%, #f7fff0 65%, #8cc56b 65%);
      overflow: hidden;
    }

    #score {
      position: absolute;
      top: 15px;
      left: 15px;
      font-size: clamp(18px, 4vw, 32px);
      font-weight: bold;
      z-index: 10;
    }

    #player {
      position: absolute;
      left: 10vw;
      bottom: 18vh;
      width: clamp(75px, 14vw, 130px);
      height: auto;
      z-index: 5;
    }

    .ground {
      position: absolute;
      bottom: 16vh;
      width: 100%;
      height: 6px;
      background: #1d1d1d;
    }

    .item,
    .obstacle {
      position: absolute;
      bottom: 18vh;
      width: clamp(45px, 9vw, 80px);
      height: auto;
      z-index: 4;
    }

    .item {
      bottom: 36vh;
    }

    #message {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      background: rgba(255,255,255,0.75);
      font-size: clamp(22px, 5vw, 42px);
      font-weight: bold;
      z-index: 20;
      padding: 30px;
    }

    .hidden {
      display: none !important;
    }
  </style>
</head>

<body>
  <div id="game">
    <div id="score">Body: 0</div>
    <img id="player" src="player-stoji.png" alt="Dobrodruh">
    <div class="ground"></div>

    <div id="message">
      Klikni nebo zmáčkni mezerník<br>
      a vyraz na výpravu!
    </div>
  </div>

  <script>
    const game = document.getElementById("game");
    const player = document.getElementById("player");
    const scoreText = document.getElementById("score");
    const message = document.getElementById("message");

    let score = 0;
    let isJumping = false;
    let isGameRunning = false;
    let gameSpeed = 5;
    let playerBottom = 18;
    let velocity = 0;

    const gravity = 0.9;
    const jumpPower = 18;

    const playerImages = [
      "player-beh1.png",
      "player-beh2.png"
    ];

    const collectImages = [
      "kompas.png",
      "mapa.png",
      "baterka.png",
      "dalekohled.png",
      "lahev.png",
      "lekarnicka.png",
      "svacina.png",
      "stan.png",
      "fotoaparat.png"
    ];

    const obstacleImages = [
      "vosi-hnizdo.png",
      "bourkovy-mrak.png",
      "blato.png",
      "spadly-strom.png",
      "rozbity-most.png",
      "jedovata-houba.png",
      "medvedi-trus.png",
      "strmy-sraz.png"
    ];

    function startGame() {
      if (!isGameRunning) {
        isGameRunning = true;
        message.classList.add("hidden");
        gameLoop();
        spawnObjects();
      } else {
        jump();
      }
    }

    function jump() {
      if (!isJumping) {
        isJumping = true;
        velocity = jumpPower;
        player.src = "player-skok.png";
      }
    }

    function gameLoop() {
      if (!isGameRunning) return;

      if (isJumping) {
        playerBottom += velocity * 0.6;
        velocity -= gravity;

        if (playerBottom <= 18) {
          playerBottom = 18;
          isJumping = false;
        }

        player.style.bottom = playerBottom + "vh";
      }

      document.querySelectorAll(".item, .obstacle").forEach(obj => {
        let left = parseFloat(obj.style.left);
        left -= gameSpeed;
        obj.style.left = left + "px";

        if (left < -120) {
          obj.remove();
        }

        if (checkCollision(player, obj)) {
          if (obj.classList.contains("item")) {
            score += 10;
            scoreText.textContent = "Body: " + score;
            obj.remove();
          } else {
            gameOver();
          }
        }
      });

      requestAnimationFrame(gameLoop);
    }

    function spawnObjects() {
      if (!isGameRunning) return;

      const isItem = Math.random() > 0.45;
      const img = document.createElement("img");

      if (isItem) {
        img.className = "item";
        img.src = collectImages[Math.floor(Math.random() * collectImages.length)];
      } else {
        img.className = "obstacle";
        img.src = obstacleImages[Math.floor(Math.random() * obstacleImages.length)];
      }

      img.style.left = window.innerWidth + "px";
      game.appendChild(img);

      const delay = Math.random() * 1200 + 900;
      setTimeout(spawnObjects, delay);
    }

    function checkCollision(a, b) {
      const r1 = a.getBoundingClientRect();
      const r2 = b.getBoundingClientRect();

      return !(
        r1.right < r2.left ||
        r1.left > r2.right ||
        r1.bottom < r2.top ||
        r1.top > r2.bottom
      );
    }

    function gameOver() {
      isGameRunning = false;
      message.innerHTML = `
        Konec výpravy!<br>
        Nasbíráno bodů: ${score}<br><br>
        Klikni pro novou hru
      `;
      message.classList.remove("hidden");
      document.querySelectorAll(".item, .obstacle").forEach(obj => obj.remove());
      score = 0;
      scoreText.textContent = "Body: 0";
      playerBottom = 18;
      player.style.bottom = playerBottom + "vh";
      player.src = "player-stoji.png";
    }

    setInterval(() => {
      if (isGameRunning && !isJumping) {
        player.src = playerImages[Math.floor(Math.random() * playerImages.length)];
      }
    }, 180);

    document.addEventListener("keydown", e => {
      if (e.code === "Space") {
        startGame();
      }
    });

    document.addEventListener("click", startGame);
    document.addEventListener("touchstart", startGame);
  </script>
</body>
</html>
